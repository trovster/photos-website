<button webc:if="photo.data.exif" type="button" title="Show Photo Metadata" class="group cursor-pointer inline-flex items-center justify-center text-gray-500 outline-offset-2 focus-visible:outline-2 transition hover:border-accent hover:text-accent focus-visible:text-accent" aria-haspopup="dialog" :aria-controls="`photo-metadata-${photo.data.id}`" :popovertarget="`photo-metadata-${photo.data.id}`">
    <svg width="26" height="26" aria-hidden="true" class="block h-6 w-6" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" data-slot="icon">
        <path stroke-linecap="round" stroke-linejoin="round" d="m11.25 11.25.041-.02a.75.75 0 0 1 1.063.852l-.708 2.836a.75.75 0 0 0 1.063.853l.041-.021M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9-3.75h.008v.008H12V8.25Z"></path>
    </svg>
    <span class="sr-only">Show Photo Metadata</span>
</button>
