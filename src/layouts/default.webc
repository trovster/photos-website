<!doctype html>
<html dir="ltr" lang="en" class="no-js">
    <head>
        <meta charset="utf-8"/>
        <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
        <meta name="author" :content="site.author"/>
        <meta name="robots" content="index,follow"/>
        <meta name="color-scheme" content="light dark"/>

        <meta name="keywords" :content="site.keywords.join(', ')"/>
        <meta name="apple-mobile-web-app-title" :content="site.title"/>
        <meta name="application-name" :content="site.title"/>

        <meta property="og:type" content="website"/>
        <meta property="og:title" :content="title === site.title ? site.title : `${title} | ${site.title}`"/>
        <meta property="og:description" name="description" :content="description ?? site.description"/>
        <meta property="og:site_name" :content="profile.name"/>

        <title @text="title === site.title ? site.title : `${title} | ${site.title}`"></title>

        <script webc:keep>
            document.documentElement.classList.replace("no-js", "js")
        </script>

        <link webc:keep rel="stylesheet" href="/css/site.css"/>

        <link rel="alternate" type="application/atom+xml" :title="site.title" href="/feed.xml" />

        <script webc:keep src="/js/site.js" type="module"></script>
    </head>
    <body :class="bodyClass ?? ''">
        <div class="container relative min-h-screen mx-auto max-w-4xl py-4">
            <site-header :profile="profile"></site-header>
            <main @raw="content"></main>
            <!-- <site-footer :navigation="navigation" :page="page"></site-footer> -->
        </div>
    </body>
</html>
