<section>
    <ul class="mx-3 mb-4 flex flex-wrap md:mx-1">
        <li webc:for="(index, photo) in paginatedPhotos" class="flex-[0_0_33.333%]">
            <photo-card :photo="photo"></photo-card>
        </li>
    </ul>

    <photo-pagination :pagination="pagination"></photo-pagination>
</section>

<site-footer :page="page"></site-footer>
